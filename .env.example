# ==============================================
# AI 服务配置
# ==============================================
# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ==============================================
# AWS Cognito（用户认证）
# ==============================================
# Cognito 用户池 ID（格式：us-east-1_XXXXXXXXX）
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
# Cognito 客户端 ID
NEXT_PUBLIC_COGNITO_CLIENT_ID=
# AWS 区域
NEXT_PUBLIC_AWS_REGION=us-east-1

# ==============================================
# AWS DynamoDB（数据持久化）
# ==============================================
# DynamoDB 表名
DYNAMODB_TABLE_NAME=douyin-scripts
# IAM 角色 Access Key（仅服务端使用，绝不暴露给客户端）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==============================================
# Sentry（错误监控，可选）
# ==============================================
NEXT_PUBLIC_SENTRY_DSN=

# ==============================================
# WebSocket（协作功能，可选）
# ==============================================
NEXT_PUBLIC_WS_URL=
